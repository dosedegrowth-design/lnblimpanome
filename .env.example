# =====================================================
# LNB Painel — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# =====================================================

# ─── Supabase ─────────────────────────────────────────
# Projeto DDG (hkjukobqpjezhpxzplpj · sa-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://hkjukobqpjezhpxzplpj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-supabase>
# Service role: usada APENAS no webhook MP (bypass RLS).
# Pegar em: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-supabase>

# ─── Auth do painel cliente ──────────────────────────
# Gere com: openssl rand -base64 48
CLIENTE_SESSION_SECRET=<chave-aleatória-min-32-chars>

# ─── Site ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://limpanomebrazil.com.br

# ─── Chatwoot (WhatsApp oficial Account 11 / Inbox 12) ─
NEXT_PUBLIC_CHATWOOT_BASE=https://dosedegrowthcrm.com.br
CHATWOOT_ACCOUNT_ID=11
CHATWOOT_INBOX_ID=12
CHATWOOT_TOKEN=GjQaMCEzK9wGwJ1u4M8p41Nj

# ─── WhatsApp Templates (Meta Cloud API oficial) ────────
# Sem template, só dá pra mandar texto livre dentro da janela 24h.
# Templates são criados no Meta Business Manager → WhatsApp → Manage templates.
# Categoria recomendada: UTILITY (notificações de transação).
#
# Idioma padrão dos templates (default: pt_BR)
WPP_TEMPLATE_LANG=pt_BR
#
# Template GENÉRICO (recomendado): aceita 4 parâmetros
#   {{1}} = primeiro nome    | ex: "João"
#   {{2}} = título da etapa  | ex: "Pagamento confirmado"
#   {{3}} = corpo da mensagem| ex: "Sua consulta foi processada..."
#   {{4}} = link da área     | ex: "https://limpanomebrazil.com.br/conta/dashboard"
WPP_TEMPLATE_GENERICO=lnb_atualizacao_processo
#
# Templates ESPECÍFICOS (opcional — sobrescreve o genérico por etapa):
# WPP_TEMPLATE_CONSULTA_PAGO=lnb_consulta_paga
# WPP_TEMPLATE_LIMPEZA_INICIADO=lnb_limpeza_iniciado
# WPP_TEMPLATE_LIMPEZA_FINALIZADO=lnb_limpeza_finalizado

# ─── Email (Resend) ──────────────────────────────────
# Domínio limpanomebrazil.com.br já verificado
RESEND_API_KEY=<re_xxxxxxxxxxxxx>
RESEND_FROM=LNB <contato@limpanomebrazil.com.br>

# ─── Mercado Pago ────────────────────────────────────
# Access Token: pegar em https://www.mercadopago.com.br/developers/panel
# Use APP_USR-... (produção ou teste, conforme aba selecionada).
MP_ACCESS_TOKEN=<APP_USR-xxxxxxxxxxxxx>

# Assinatura secreta do webhook MP (valida HMAC SHA256).
# Pegar em: Painel MP → sua aplicação → Webhooks → "Assinatura secreta"
# Sem ela, o webhook aceita requisições sem validar (INSEGURO em prod).
MP_WEBHOOK_SECRET=<assinatura-secreta-mp>

# ─── API Full (consulta CPF) ─────────────────────────
API_FULL_TOKEN=<token-api-full>

# ─── Webhook PDF (n8n) ───────────────────────────────
# Workflow PDF Generator gera o relatório PDF da consulta.
LNB_PDF_WEBHOOK=<url-webhook-n8n-pdf-generator>
